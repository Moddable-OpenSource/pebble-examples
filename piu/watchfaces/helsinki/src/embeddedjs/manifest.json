{
	"config": {
		"icon": "./icon.png",
		"watchface": true
	},
	"modules": {
		"*": "./main"
	},
	"platforms": {
		"*/flint": {
			"modules": {
				"*": "./flint/layout"
			},
			"resources": {
				"*-alpha": "./flint/digits"
			}
		},
		"*/emery": {
			"modules": {
				"*": "./emery/layout"
			},
			"resources": {
				"*-alpha": "./emery/digits"
			}
		},
		"...": {
			"error": "Platform not supported"
		}
	},
	"include": [
		"$(MODDABLE)/examples/manifest_mod.json",
		"$(MODDABLE)/examples/manifest_typings.json"
	]
}
